#include "main.h"

/**
 *pirt_alaphabet -prints the alphabet in lowercase followed by a new line
 *

void print_alphabet(void)
{
    char alphabet[26] = { 'a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 
                          'j','k','l','m','n','o','p','q','r','s',
			  't','u','v','w','x','y','z'};
    int i;
    for( i = 0; i<26; i++)
    {
      _putchar(alphabet[i]);
    }
    _putchar('\n');
}
